# Monorepo root ignore rules for Laravel backend + Next.js frontend

# OS/editor clutter
.DS_Store
Thumbs.db
.vscode/
.idea/
.fleet/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment and secrets
.env
.env.*
!.env.example

# Dependency directories
node_modules/
backend/vendor/
frontend/node_modules/

# Laravel backend artifacts
backend/.phpunit.cache
backend/.phpunit.result.cache
backend/public/build/
backend/public/hot
backend/public/storage
backend/storage/*.key
backend/auth.json
backend/Homestead.json
backend/Homestead.yaml

# Next.js frontend artifacts
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/
frontend/*.tsbuildinfo
frontend/next-env.d.ts
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions
frontend/.vercel

# Local Docker/runtime temp files
*.pid
*.seed
*.pid.lock
